# ══════════════════════════════════════════════════════════════════
# IBKR Gateway — Environment Variable Template
# Copy this file to .env in the project root and fill in your values.
# Never commit a real .env file to version control.
# ══════════════════════════════════════════════════════════════════

# ── Connection ─────────────────────────────────────────────────────
# IB Gateway paper:  port 4002
# TWS paper:         port 7497
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=7

# Optional: specify your IBKR account string (e.g. DU1234567)
# Leave blank to use the default paper account.
IBKR_ACCOUNT=

# ── Safety gates ───────────────────────────────────────────────────
# Set IBKR_READONLY=false ONLY when you are ready to trade.
IBKR_READONLY=true

# Set ALLOW_LIVE_ORDERS=true ONLY together with IBKR_READONLY=false.
ALLOW_LIVE_ORDERS=false

# ── Emergency kill switch ──────────────────────────────────────────
# Setting KILL_SWITCH=true blocks ALL new orders immediately.
# The system will still run and log signals — nothing is placed.
KILL_SWITCH=false

