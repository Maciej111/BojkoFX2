# BojkoIDX — IBKR configuration
# Deploy to: /home/macie/bojkoidx/config/ibkr.env
#
# CRITICAL: client_id=8 must differ from BojkoFX (client_id=7)
# Both bots connect to the SAME IB Gateway (port 4002) simultaneously.

IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=8
IBKR_ACCOUNT=DUP994821
IBKR_READONLY=false
ALLOW_LIVE_ORDERS=true
KILL_SWITCH=false

# Optional: fix account equity used for position sizing
# (useful if paper account equity deviates from expected)
# RISK_EQUITY_OVERRIDE=10000

# Optional: override default 0.5% risk per trade
# RISK_FRACTION=0.005
